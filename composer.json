{
    "name": "labrodev/document-sampler",
    "description": "Extracts a structured representative sample from long documents for downstream AI processing.",
    "type": "library",
    "version": "1.0.0",
    "license": "MIT",
    "authors": [
        {
            "name": "Petro Lashyn",
            "email": "contact@labrodev.com"
        }
    ],
    "require": {
        "php": "^8.5"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Labrodev\\DocumentSampler\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Labrodev\\DocumentSampler\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
